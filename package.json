{
  "name": "opendesign",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "storybook": "pnpm -r --filter './storybooks/*' --parallel storybook",
    "storybook:vue": "pnpm --filter '@openstory/vue' storybook",
    "storybook:react": "pnpm --filter '@openstory/react' storybook",
    "storybook:host": "pnpm --filter '@openstory/host' storybook"
  },
  "devDependencies": {
    "@opendesign/tsconfig": "workspace:*",
    "typescript": "^5.9.3"
  }
}
